# Публичные (браузер + подстановка при next build)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# или NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Сервер и proxy — те же значения; подхватываются при next dev / next start / Vercel
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=
# или SUPABASE_ANON_KEY= (классический anon из API)

# Supabase Dashboard → Authentication → URL Configuration
# Site URL: http://localhost:3000 (локально) или https://<project>.vercel.app / свой домен
# Redirect URLs: полный URL обработчика подтверждения почты, например:
#   http://localhost:3000/auth/confirm
#   https://<project>.vercel.app/auth/confirm
# Без этого ссылка из письма регистрации может не пройти проверку редиректа.
#
# Vercel: те же переменные в Project → Settings → Environment Variables (Production + Preview).
